# ============================================================================
# AI Configuration
# ============================================================================
# Centralized AI configuration for the Reme application
# Copy relevant settings to your .env.local or .env.production
# All settings are optional - defaults will be used if not specified
# ============================================================================

# ----------------------------------------------------------------------------
# Default Provider & Model Settings
# ----------------------------------------------------------------------------
# Default AI provider for all operations (unless overridden)
# Options: gateway | gemini | openai | openrouter | groq
# Default: gemini
AI_DEFAULT_PROVIDER=gemini

# Default model tier for all operations
# Options: smartest | smart | regular
# Default: smart
AI_DEFAULT_TIER=smart

# Default temperature for generation (0.0 = deterministic, 2.0 = very creative)
# Default: 0.7
AI_DEFAULT_TEMPERATURE=0.7

# Maximum number of tool calling steps allowed per request
# Higher = more complex multi-step operations, but slower
# Default: 5
AI_MAX_TOOL_STEPS=5

# ----------------------------------------------------------------------------
# Chat Configuration
# ----------------------------------------------------------------------------
# Override provider specifically for chat (inherits AI_DEFAULT_PROVIDER if not set)
# AI_CHAT_PROVIDER=gemini

# Override tier specifically for chat (inherits AI_DEFAULT_TIER if not set)
# AI_CHAT_TIER=smart

# Override temperature specifically for chat
# AI_CHAT_TEMPERATURE=0.7

# Override max steps specifically for chat
# AI_CHAT_MAX_STEPS=5

# ----------------------------------------------------------------------------
# Suggestion Generation Configuration
# ----------------------------------------------------------------------------
# Provider for suggestion generation (optimized for speed)
# Default: gemini
AI_SUGGESTIONS_PROVIDER=gemini

# Tier for suggestion generation (regular = fastest, cheapest)
# Default: regular
AI_SUGGESTIONS_TIER=regular

# Temperature for suggestion generation
# Default: 0.7
AI_SUGGESTIONS_TEMPERATURE=0.7

# Prompt version to use for suggestions (v1 or v2)
# v1 = Basic follow-up questions
# v2 = Context-aware with priority hints (recommended)
# Default: v2
AI_SUGGESTIONS_PROMPT_VERSION=v2

# Minimum number of suggestions to generate
# Default: 2
AI_SUGGESTIONS_MIN=2

# Maximum number of suggestions to generate
# Default: 4
AI_SUGGESTIONS_MAX=4

# Maximum words per suggestion
# Default: 8
AI_SUGGESTIONS_MAX_WORDS=8

# Character limit for AI response context passed to suggestion generation
# Default: 500
AI_SUGGESTIONS_CONTEXT_LIMIT=500

# ----------------------------------------------------------------------------
# Prompt Versions
# ----------------------------------------------------------------------------
# Active system prompt version
# Default: v1
AI_SYSTEM_PROMPT_VERSION=v1

# Active suggestion prompt version (also configurable via AI_SUGGESTIONS_PROMPT_VERSION)
# Default: v2
AI_SUGGESTION_PROMPT_VERSION=v2

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Enable memory/context retention (requires mem0 or similar)
# Default: false
AI_ENABLE_MEMORY=false

# Enable message persistence to Convex database
# Default: false
AI_ENABLE_MESSAGE_PERSISTENCE=false

# Enable usage analytics tracking
# Default: false
AI_ENABLE_ANALYTICS=false

# Enable A/B testing for prompts
# Default: false
AI_ENABLE_PROMPT_AB_TESTING=false

# ----------------------------------------------------------------------------
# Performance Settings
# ----------------------------------------------------------------------------
# Enable streaming responses (disable for debugging)
# Default: true
AI_ENABLE_STREAMING=true

# Request timeout in milliseconds
# Default: 60000 (60 seconds)
AI_REQUEST_TIMEOUT=60000

# Enable caching of AI responses (requires implementation)
# Default: false
AI_ENABLE_CACHING=false

# Cache TTL in seconds (1 hour = 3600)
# Default: 3600
AI_CACHE_TTL=3600

# ----------------------------------------------------------------------------
# Debug Settings
# ----------------------------------------------------------------------------
# Enable debug logging (auto-enabled in NODE_ENV=development)
# Default: false (true in development)
AI_DEBUG=false

# ============================================================================
# Example Configurations
# ============================================================================

# PRODUCTION - Balanced performance and cost
# AI_DEFAULT_PROVIDER=gemini
# AI_DEFAULT_TIER=smart
# AI_SUGGESTIONS_TIER=regular
# AI_ENABLE_STREAMING=true
# AI_ENABLE_ANALYTICS=true

# PRODUCTION - Maximum quality (higher cost)
# AI_DEFAULT_PROVIDER=openai
# AI_DEFAULT_TIER=smartest
# AI_SUGGESTIONS_PROVIDER=openai
# AI_SUGGESTIONS_TIER=smart

# PRODUCTION - Cost-optimized
# AI_DEFAULT_PROVIDER=groq
# AI_DEFAULT_TIER=smart
# AI_SUGGESTIONS_PROVIDER=groq
# AI_SUGGESTIONS_TIER=regular
# AI_ENABLE_CACHING=true

# DEVELOPMENT - Fast iteration
# AI_DEFAULT_PROVIDER=gemini
# AI_DEFAULT_TIER=regular
# AI_DEBUG=true
# AI_ENABLE_STREAMING=false

# DEVELOPMENT - OpenRouter for model variety
# AI_DEFAULT_PROVIDER=openrouter
# AI_DEFAULT_TIER=smart
# AI_DEBUG=true

# ============================================================================
# Notes
# ============================================================================
# 1. All AI_* environment variables are optional
# 2. If not set, sensible defaults will be used
# 3. Chat and suggestions can use different providers/tiers
# 4. Debug mode is auto-enabled in development
# 5. See src/lib/ai/config.ts for full documentation
# ============================================================================

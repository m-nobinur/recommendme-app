# Convex Configuration
# These are auto-set by `npx convex dev` on first run
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name
MEMORY_API_TOKEN=replace-with-random-secret

# Authentication (better-auth)
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# ─── Development Mode ────────────────────────────────────────
# Set DISABLE_AUTH_IN_DEV=true to bypass authentication in dev.
# Then run: npx convex run devSetup:createDevEnvironment '{"authUserId":"dev-user-id"}'
# Copy the returned IDs here:
# DISABLE_AUTH_IN_DEV=true
# DEV_ORGANIZATION_ID=<paste-org-id-from-devSetup>
# DEV_USER_ID=<paste-user-id-from-devSetup>

# ─── Memory API Security ──────────────────────────────────────
# Protects public Convex memory retrieval/event endpoints.
# Generate with one of:
#   openssl rand -base64 48
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# IMPORTANT: use the same value in both places:
#   1) .env.local (this file)
#   2) Convex deployment env:
#      npx convex env set MEMORY_API_TOKEN '<your-token>'
#
# In production this token is required (fail-closed).

# ─── AI Feature Flags ────────────────────────────────────────
# AI_ENABLE_MEMORY=true           # Enable memory retrieval in chat
# AI_ENABLE_MESSAGE_PERSISTENCE=true  # Persist messages to Convex
# AI_DEBUG=true                   # Verbose AI logging

# AI Providers (configure at least one)
# Google Gemini - Recommended for development
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# OpenAI - GPT models including reasoning capabilities
OPENAI_API_KEY=sk-your-openai-api-key

# OpenRouter - Access to 100+ models from multiple providers
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Groq - Ultra-fast inference with LPU technology
GROQ_API_KEY=gsk_your-groq-api-key

# AI Gateway - Vercel AI Gateway (optional, auto-authenticated on Vercel)
AI_GATEWAY_API_KEY=your-gateway-api-key

# Application URL (used for provider attribution)
NEXT_PUBLIC_APP_URL=http://localhost:3000
